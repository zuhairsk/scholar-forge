{
  "include": [
    "next-env.d.ts",
    "app/**/*",
    "src/**/*",
    "lib/**/*",
    "types/**/*.d.ts",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "dist",
    "build",
    "**/*.test.ts"
  ],
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "jsx": "preserve",
    "lib": [
      "esnext",
      "dom",
      "dom.iterable"
    ],
    "resolveJsonModule": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2022",
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "types": [
      "node"
    ],
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./src/*"],
      "wouter": [
        "./src/shims/wouter"
      ]
    },
    "incremental": true,
    "esModuleInterop": true,
    "isolatedModules": true
  }
}
